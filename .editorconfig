root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
indent_style = space
max_line_length = off
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Compose: @Composable functions are PascalCase by convention. The default ktlint rule
# (correctly for non-Compose Kotlin) wants camelCase, but every UI screen and row in this
# project is a composable.
ktlint_standard_function-naming = disabled

# Backing properties (`_uiState`, `_currentPositionMs`, etc.) follow the Kotlin coroutines
# docs convention. Plus `UiTestTags` consts are camelCase by design — they're string
# values that appear in Compose semantics, not Kotlin compile-time constants.
ktlint_standard_property-naming = disabled
